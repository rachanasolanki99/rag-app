# ──────────────────────────────────────────────────────────────
#  RAG Docs Assistant – environment configuration
#  Copy this file to `.env` and adjust values as needed.
#  It works out-of-the-box with the defaults below (mock LLM mode).
# ──────────────────────────────────────────────────────────────

# ---- Service ports ----
INGESTION_PORT=4001
QUERY_PORT=4002

# ---- API security ----
# Every request must send header:  x-api-key: <this value>
API_KEY=dev-secret-key

# ---- PostgreSQL (relational + pgvector) ----
# Default is for running Node services directly on your machine.
# Docker Compose overrides this to use host "postgres" inside the Docker network.
DATABASE_URL=postgres://rag:ragpass@localhost:5432/ragdb

# ---- RabbitMQ (message queue) ----
# Default is for running Node services directly on your machine.
# Docker Compose overrides this to use host "rabbitmq" inside the Docker network.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
INGESTION_QUEUE=document.ingest

# ---- LLM / Embeddings provider ----
# Provider options: mock | gemini | openai
# "mock"   -> runs with NO API key (deterministic fake embeddings + extractive answer). Great for demos.
# "gemini" -> set GEMINI_API_KEY (free tier: https://aistudio.google.com/app/apikey)
# "openai" -> set OPENAI_API_KEY
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# Embedding vector dimension. Must match the provider:
#   mock   -> 768
#   gemini (text-embedding-004) -> 768
#   openai (text-embedding-3-small) -> 1536
EMBEDDING_DIM=768

GEMINI_API_KEY=
GEMINI_EMBED_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ---- RAG tuning ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4

# ---- Observability ----
LOG_LEVEL=info
# Enable OpenTelemetry tracing (true/false). If true, set an OTLP endpoint.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
